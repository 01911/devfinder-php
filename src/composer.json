{
  "name": "devfinder/api",
  "description": "DevFinder API - PHP 8.2+ DDD Implementation",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "firebase/jwt": "^6.9"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Illuminate\\": "app/Illuminate/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
